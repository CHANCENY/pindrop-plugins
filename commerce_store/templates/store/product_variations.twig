{% extends "templates/base.twig" %}

{% block title %}Product Variations - {{ product.name }}{% endblock %}

{% block head %}
    <link rel="stylesheet" href="/modules/commerce_store/assets/css/product-variations.css">
    <link rel="stylesheet" href="/modules/commerce_store/assets/css/list-products.css">
{% endblock %}

{% block content %}
    <div class="drupal-variations-container">

        <!-- Page Header -->
        <div class="page-header">
            <div class="page-header-content">
                <div class="page-title">
                    <h1>Product Variations</h1>
                    <p>Manage variations for: <strong>{{ product.name }}</strong></p>
                </div>
                <div class="page-actions">
                    <a href="{{ url('commerce_store.products.view', {id: product.id}) }}" class="btn">
                        Back to Product
                    </a>
                    <a href="{{ url('commerce_store.products.variations.create', {id: product.id}) }}" class="btn btn-primary">
                        Create Variation
                    </a>
                    <a type="button" class="btn btn-secondary" onclick="showImportModal()">
                        Import Products
                    </a>
                </div>
            </div>
        </div>

        <!-- Success and Error Messages -->
        {% if success %}
            <div class="alert alert-success" style="padding: 1rem; background: #d4edda; color: #155724; border: 1px solid #c3e6cb; margin-bottom: 1rem;">
                {{ success }}
            </div>
        {% endif %}

        {% if error %}
            <div class="alert alert-danger" style="padding: 1rem; background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; margin-bottom: 1rem;">
                {{ error }}
            </div>
        {% endif %}

        <!-- Product Info (Seamless Grid) -->
        <div class="product-info-section">
            <div class="info-grid">
                <div class="info-item">
                    <label>Product SKU</label>
                    <span>{{ product.sku }}</span>
                </div>
                <div class="info-item">
                    <label>Product Type</label>
                    <div><span class="badge badge-variable">Variable Product</span></div>
                </div>
                <div class="info-item">
                    <label>Total Variations</label>
                    <span>{{ variations|length }}</span>
                </div>
            </div>
        </div>

        <!-- Filters Section -->
        <div class="filters-section">
            <form method="GET" action="{{ current_url }}" class="filter-form">
                <div class="filter-grid">
                    <div class="filter-group">
                        <label for="status" class="filter-label">Status</label>
                        <select name="status" id="status" class="form-control">
                            <option value="">All Status</option>
                            <option value="draft" {% if filters.status == 'draft' %}selected{% endif %}>Draft</option>
                            <option value="publish" {% if filters.status == 'publish' %}selected{% endif %}>Published</option>
                        </select>
                    </div>

                    <div class="filter-group">
                        <label for="stock_status" class="filter-label">Stock Status</label>
                        <select name="stock_status" id="stock_status" class="form-control">
                            <option value="">All Stock Status</option>
                            <option value="instock" {% if filters.stock_status == 'instock' %}selected{% endif %}>In Stock</option>
                            <option value="outofstock" {% if filters.stock_status == 'outofstock' %}selected{% endif %}>Out of Stock</option>
                            <option value="onbackorder" {% if filters.stock_status == 'onbackorder' %}selected{% endif %}>On Backorder</option>
                        </select>
                    </div>

                    <div class="filter-group">
                        <label for="featured" class="filter-label">Featured</label>
                        <select name="featured" id="featured" class="form-control">
                            <option value="">All Variations</option>
                            <option value="1" {% if filters.featured == '1' %}selected{% endif %}>Featured Only</option>
                            <option value="0" {% if filters.featured == '0' %}selected{% endif %}>Not Featured</option>
                        </select>
                    </div>

                    <div class="filter-group">
                        <label for="catalog_visibility" class="filter-label">Visibility</label>
                        <select name="catalog_visibility" id="catalog_visibility" class="form-control">
                            <option value="">All Visibility</option>
                            <option value="visible" {% if filters.catalog_visibility == 'visible' %}selected{% endif %}>Visible</option>
                            <option value="catalog" {% if filters.catalog_visibility == 'catalog' %}selected{% endif %}>Catalog Only</option>
                            <option value="search" {% if filters.catalog_visibility == 'search' %}selected{% endif %}>Search Only</option>
                            <option value="hidden" {% if filters.catalog_visibility == 'hidden' %}selected{% endif %}>Hidden</option>
                        </select>
                    </div>

                    <div class="filter-group">
                        <label for="manage_stock" class="filter-label">Stock Management</label>
                        <select name="manage_stock" id="manage_stock" class="form-control">
                            <option value="">All</option>
                            <option value="1" {% if filters.manage_stock == '1' %}selected{% endif %}>Manage Stock</option>
                            <option value="0" {% if filters.manage_stock == '0' %}selected{% endif %}>Don't Manage Stock</option>
                        </select>
                    </div>

                    <div class="filter-group">
                        <label for="search" class="filter-label">Search</label>
                        <input type="text" name="search" id="search" class="form-control" 
                               value="{{ filters.search ?? '' }}" placeholder="Search by name or SKU...">
                    </div>

                    <div class="filter-actions">
                        <button type="submit" class="btn btn-primary">Filter</button>
                        <a href="{{ url('commerce_store.products.variations', {id: product.id}) }}" class="btn">Clear</a>
                    </div>
                </div>
            </form>
        </div>

        <!-- Variations List (Seamless Table Grid) -->
        <div class="variations-section">
            {% if variations|length > 0 %}
                <div class="table-responsive">
                    <table class="variations-table">
                        <thead>
                        <tr>
                            <th>Variation</th>
                            <th>SKU</th>
                            <th>Price</th>
                            <th>Stock</th>
                            <th>Weight</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for variation in variations %}
                            <tr>
                                <td class="col-name">
                                    <div class="variation-name">
                                        {{ variation.name }}
                                        {% if variation.attributes %}
                                            <div class="variation-attributes">
                                                {% for attribute in variation.attributes|json_decode %}
                                                    <span class="attribute-badge">{{ attribute.name }}: {{ attribute.value }}</span>
                                                {% endfor %}
                                            </div>
                                        {% endif %}
                                    </div>
                                </td>
                                <td class="col-sku">
                                    <code>{{ variation.sku }}</code>
                                </td>
                                <td class="col-price">
                                    {% if variation.sale_price %}
                                        <div class="sale-price" style="font-weight: 700;">${{ variation.sale_price }}</div>
                                        <div class="regular-price" style="text-decoration: line-through; color: #999; font-size: 0.8rem;">${{ variation.regular_price }}</div>
                                    {% else %}
                                        <span class="regular-price" style="font-weight: 700;">${{ variation.regular_price }}</span>
                                    {% endif %}
                                </td>
                                <td class="col-stock">
                                    {% if variation.manage_stock %}
                                        <div class="stock-quantity" style="font-weight: 700;">{{ variation.stock_quantity }}</div>
                                        <div class="stock-status {{ variation.stock_status }}" style="font-size: 0.8rem;">
                                            {{ variation.stock_status == 'instock' ? 'In Stock' : 'Out of Stock' }}
                                        </div>
                                    {% else %}
                                        <span class="stock-status">Unlimited</span>
                                    {% endif %}
                                </td>
                                <td class="col-weight">
                                    {{ variation.weight ? variation.weight ~ ' kg' : '-' }}
                                </td>
                                <td class="col-status">
                                    <span class="status-badge status-{{ variation.status }}">
                                        {{ variation.status == 'publish' ? 'Published' : 'Draft' }}
                                    </span>
                                </td>
                                <td class="col-actions">
                                    <div class="action-buttons">
                                        <button type="button" class="btn btn-sm" onclick="editVariation({{ variation.id }}, '{{ variation.name|escape('js') }}', '{{ variation.sku|escape('js') }}', {{ variation.regular_price }}, {{ variation.sale_price }}, {{ variation.stock_quantity }})">
                                            Edit
                                        </button>
                                        <a type="button" class="btn btn-sm" href="{{ url('commerce_store.products.variations.view', {id: product.id, variation_id: variation.id}) }}">
                                            View Details
                                        </a>
                                        <a type="button" class="btn btn-sm" href="{{ url('commerce_store.products.variations.attributes', {id: product.id, variation_id: variation.id}) }}">
                                            Attributes
                                        </a>
                                        <button type="button" class="btn btn-sm btn-danger" onclick="confirmDeleteVariation({{ variation.id }}, '{{ variation.name|escape('js') }}')">
                                            Delete
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="empty-state">
                    <h3>No variations found</h3>
                    <p>This product doesn't have any variations yet.</p>
                    <div style="margin-top: 1rem;">
                        <button type="button" class="btn btn-primary" onclick="showAddVariationForm()">
                            Create First Variation
                        </button>
                    </div>
                </div>
            {% endif %}
        </div>

        <!-- Pagination -->
        {% if total_pages > 1 %}
        <div class="pagination-section">
            <div class="pagination-info">
                Showing {{ ((current_page - 1) * per_page) + 1 }} to 
                {{ [current_page * per_page, total_items]|min }} of {{ total_items }} variations
            </div>
            <div class="pagination-controls">
                {% if current_page > 1 %}
                    <a href="{{ url('commerce_store.products.variations', {id: product.id, page: current_page - 1, per_page: per_page}) }}" 
                       class="btn btn-sm btn-secondary">
                        <i class="icon-arrow-left"></i> Previous
                    </a>
                {% endif %}
                
                <div class="page-numbers">
                    {% set start_page = [1, current_page - 2]|max %}
                    {% set end_page = [total_pages, current_page + 2]|min %}
                    
                    {% if start_page > 1 %}
                        <a href="{{ url('commerce_store.products.variations', {id: product.id, page: 1, per_page: per_page}) }}" 
                           class="page-link">1</a>
                        {% if start_page > 2 %}
                            <span class="page-ellipsis">...</span>
                        {% endif %}
                    {% endif %}
                    
                    {% for page in range(start_page, end_page) %}
                        {% if page == current_page %}
                            <span class="page-link current">{{ page }}</span>
                        {% else %}
                            <a href="{{ url('commerce_store.products.variations', {id: product.id, page: page, per_page: per_page}) }}" 
                               class="page-link">{{ page }}</a>
                        {% endif %}
                    {% endfor %}
                    
                    {% if end_page < total_pages %}
                        {% if end_page < total_pages - 1 %}
                            <span class="page-ellipsis">...</span>
                        {% endif %}
                        <a href="{{ url('commerce_store.products.variations', {id: product.id, page: total_pages, per_page: per_page}) }}" 
                           class="page-link">{{ total_pages }}</a>
                    {% endif %}
                </div>
                
                {% if current_page < total_pages %}
                    <a href="{{ url('commerce_store.products.variations', {id: product.id, page: current_page + 1, per_page: per_page}) }}" 
                       class="btn btn-sm btn-secondary">
                        Next <i class="icon-arrow-right"></i>
                    </a>
                {% endif %}
            </div>
            
            <div class="per-page-selector">
                <label for="per_page">Show:</label>
                <select id="per_page" onchange="changePerPage(this.value)">
                    <option value="10" {{ per_page == 10 ? 'selected' : '' }}>10</option>
                    <option value="25" {{ per_page == 25 ? 'selected' : '' }}>25</option>
                    <option value="50" {{ per_page == 50 ? 'selected' : '' }}>50</option>
                    <option value="100" {{ per_page == 100 ? 'selected' : '' }}>100</option>
                </select>
                per page
            </div>
        </div>
        {% endif %}

    </div>

    <!-- Import Products Modal -->
    <div id="importModal" class="modal" style="display: none;">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Import Products Variations</h3>
                <button type="button" class="modal-close" onclick="hideImportModal()">&times;</button>
            </div>
            <div class="modal-body">
                <form id="importForm" action="{{ url('commerce_store.products.variations.import') }}" method="POST" enctype="multipart/form-data">
                    <div class="form-group">
                        <label for="import_file" class="form-label">CSV File *</label>
                        <input type="file" id="import_file" name="import_file" accept=".csv" required>
                        <div class="form-text">Upload a CSV file with product variations data. Maximum file size: 10MB</div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Import Options</label>
                        <div class="checkbox-group">
                            <div class="form-check">
                                <input type="checkbox" id="update_existing" name="update_existing" value="1">
                                <label class="form-check-label" for="update_existing">Update existing products if SKU matches</label>
                            </div>
                            <div class="form-check">
                                <input type="checkbox" id="skip_first_row" name="skip_first_row" value="1" checked>
                                <label class="form-check-label" for="skip_first_row">Skip first row (header row)</label>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Required CSV Columns</label>
                        <div class="csv-columns">
                            <div class="column-item">
                                <span class="required">SKU *</span>
                                <small>Product unique identifier</small>
                            </div>
                            <div class="column-item">
                                <span class="required">Name *</span>
                                <small>Product name</small>
                            </div>
                            <div class="column-item">
                                <span class="optional">Regular Price *</span>
                                <small>Product price</small>
                            </div>
                            <div class="column-item">
                                <span class="optional">Description</span>
                                <small>Product description</small>
                            </div>
                            <div class="column-item">
                                <span class="optional">Stock Quantity</span>
                                <small>Available stock</small>
                            </div>
                            <div class="column-item">
                                <span class="optional">Status</span>
                                <small>draft or publish</small>
                            </div>
                        </div>
                        <div class="template-download">
                            <a href="/modules/commerce_store/assets/product_variation_template.csv" download="product_template.csv" class="btn btn-outline btn-sm">
                                <i class="icon-download"></i> Download Template
                            </a>
                            <small>Download this CSV template to see the expected format</small>
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Import Variations</button>
                        <button type="button" class="btn btn-secondary" onclick="hideImportModal()">Cancel</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

{% endblock %}

{% block scripts %}
    <script>
        function showAddVariationForm() {
            document.getElementById('variationModalTitle').textContent = 'Add Product Variation';
            document.getElementById('variationForm').reset();
            document.getElementById('variation_id').value = '';
            document.getElementById('variationModal').style.display = 'block';
            document.body.style.overflow = 'hidden';
        }

        function hideVariationForm() {
            document.getElementById('variationModal').style.display = 'none';
            document.body.style.overflow = 'auto';
        }

        function editVariation(id, name, sku, regularPrice, salePrice, stockQuantity) {
            window.location.href = '{{ url("commerce_store.products.variations.edit", {id: product.id, variation_id: "VARIATION_ID"}) }}'.replace('VARIATION_ID', id);
        }

        function confirmDeleteVariation(variationId, variationName) {
            if (confirm('Are you sure you want to delete "' + variationName + '"? This action cannot be undone.')) {
                window.location.href = `/admin/com/store/products/variations/${variationId}/delete`;
            }
        }

        function showImportModal() {
            document.getElementById('importModal').style.display = 'block';
            document.body.style.overflow = 'hidden';
        }

        function hideImportModal() {
            document.getElementById('importModal').style.display = 'none';
            document.body.style.overflow = 'auto';
        }

        function changePerPage(perPage) {
            const url = new URL(window.location.href);
            url.searchParams.set('per_page', perPage);
            url.searchParams.set('page', '1');
            window.location.href = url.toString();
        }

        // Close modal when clicking outside
        window.onclick = function(event) {
            const modal = document.getElementById('importModal');
            if (event.target == modal) {
                hideImportModal();
            }
        }

    </script>
{% endblock %}