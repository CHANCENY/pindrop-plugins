{% extends "templates/base.twig" %}

{% block title %}Store Settings{% endblock %}

{% block content %}
<div class="store-settings">
    <div class="settings-header">
        <h1 class="settings-title">Store Settings</h1>
        <p class="settings-subtitle">Manage your store configuration and preferences</p>
    </div>

    <!-- Success/Error Messages -->
    {% if success %}
    <div class="notification success show">
        {{ success }}
    </div>
    {% endif %}

    {% if error %}
    <div class="notification error show">
        {{ error }}
    </div>
    {% endif %}

    <form class="settings-form" method="POST" enctype="multipart/form-data" id="storeSettingsForm">
        <!-- Basic Information -->
        <div class="settings-section">
            <h2 class="section-title">Basic Information</h2>
            <div class="form-grid">
                <div class="form-group">
                    <label for="store_name" class="form-label">Store Name *</label>
                    <input type="text" id="store_name" name="store_name" class="form-input" value="{{ store.store_name|default('') }}" required>
                    <span class="form-hint">This will be displayed to customers</span>
                </div>
                
                <div class="form-group">
                    <label for="store_slug" class="form-label">Store URL Slug *</label>
                    <input type="text" id="store_slug" name="store_slug" class="form-input" value="{{ store.store_slug|default('') }}" required>
                    <span class="form-hint">URL-friendly identifier (e.g., my-awesome-store)</span>
                </div>
                
                <div class="form-group full-width">
                    <label for="store_description" class="form-label">Store Description</label>
                    <textarea id="store_description" name="store_description" class="form-textarea" rows="4">{{ store.store_description|default('') }}</textarea>
                    <span class="form-hint">Describe your store to customers</span>
                </div>
            </div>
        </div>

        <!-- Contact Information -->
        <div class="settings-section">
            <h2 class="section-title">Contact Information</h2>
            <div class="form-grid">
                <div class="form-group">
                    <label for="store_email" class="form-label">Store Email</label>
                    <input type="email" id="store_email" name="store_email" class="form-input" value="{{ store.store_email|default('') }}">
                    <span class="form-hint">Customer support email</span>
                </div>
                
                <div class="form-group">
                    <label for="store_phone" class="form-label">Store Phone</label>
                    <input type="tel" id="store_phone" name="store_phone" class="form-input" value="{{ store.store_phone|default('') }}">
                    <span class="form-hint">Customer support phone number</span>
                </div>
                
                <div class="form-group full-width">
                    <label for="store_website" class="form-label">Store Website</label>
                    <input type="url" id="store_website" name="store_website" class="form-input" value="{{ store.store_website|default('') }}">
                    <span class="form-hint">External website URL (optional)</span>
                </div>
            </div>
        </div>

        <!-- Address Information -->
        <div class="settings-section">
            <h2 class="section-title">Business Address</h2>
            <div class="form-grid">
                <div class="form-group full-width">
                    <label for="store_address" class="form-label">Street Address</label>
                    <input type="text" id="store_address" name="store_address" class="form-input" value="{{ store.store_address|default('') }}">
                </div>
                
                <div class="form-group">
                    <label for="store_city" class="form-label">City</label>
                    <input type="text" id="store_city" name="store_city" class="form-input" value="{{ store.store_city|default('') }}">
                </div>
                
                <div class="form-group">
                    <label for="store_state" class="form-label">State/Province</label>
                    <input type="text" id="store_state" name="store_state" class="form-input" value="{{ store.store_state|default('') }}">
                </div>
                
                <div class="form-group">
                    <label for="store_country" class="form-label">Country</label>
                    <select id="store_country" name="store_country" class="form-select">
                        <option value="">Select Country</option>
                        <option value="US" {% if store.store_country == 'US' %}selected{% endif %}>United States</option>
                        <option value="CA" {% if store.store_country == 'CA' %}selected{% endif %}>Canada</option>
                        <option value="GB" {% if store.store_country == 'GB' %}selected{% endif %}>United Kingdom</option>
                        <option value="AU" {% if store.store_country == 'AU' %}selected{% endif %}>Australia</option>
                        <option value="IN" {% if store.store_country == 'IN' %}selected{% endif %}>India</option>
                        <!-- Add more countries as needed -->
                    </select>
                </div>
                
                <div class="form-group">
                    <label for="store_postal_code" class="form-label">Postal/Zip Code</label>
                    <input type="text" id="store_postal_code" name="store_postal_code" class="form-input" value="{{ store.store_postal_code|default('') }}">
                </div>
            </div>
        </div>

        <!-- Business Information -->
        <div class="settings-section">
            <h2 class="section-title">Business Information</h2>
            <div class="form-grid">
                <div class="form-group">
                    <label for="business_type" class="form-label">Business Type *</label>
                    <select id="business_type" name="business_type" class="form-select" required>
                        <option value="individual" {% if store.business_type == 'individual' %}selected{% endif %}>Individual</option>
                        <option value="company" {% if store.business_type == 'company' %}selected{% endif %}>Company</option>
                        <option value="partnership" {% if store.business_type == 'partnership' %}selected{% endif %}>Partnership</option>
                        <option value="corporation" {% if store.business_type == 'corporation' %}selected{% endif %}>Corporation</option>
                        <option value="non_profit" {% if store.business_type == 'non_profit' %}selected{% endif %}>Non-Profit</option>
                    </select>
                </div>
                
                <div class="form-group">
                    <label for="business_registration_number" class="form-label">Business Registration Number</label>
                    <input type="text" id="business_registration_number" name="business_registration_number" class="form-input" value="{{ store.business_registration_number|default('') }}">
                </div>
                
                <div class="form-group">
                    <label for="tax_id" class="form-label">Tax ID</label>
                    <input type="text" id="tax_id" name="tax_id" class="form-input" value="{{ store.tax_id|default('') }}">
                </div>
            </div>
        </div>

        <!-- Store Configuration -->
        <div class="settings-section">
            <h2 class="section-title">Store Configuration</h2>
            <div class="form-grid">
                <div class="form-group">
                    <label for="currency" class="form-label">Default Currency *</label>
                    <select id="currency" name="currency" class="form-select" required>
                        {% for code, name in currencies %}
                        <option value="{{ code }}" {% if store.currency == code %}selected{% endif %}>{{ name }}</option>
                        {% endfor %}
                    </select>
                </div>
                
                <div class="form-group">
                    <label for="timezone" class="form-label">Timezone</label>
                    <select id="timezone" name="timezone" class="form-select">
                        <option value="UTC" {% if store.timezone == 'UTC' %}selected{% endif %}>UTC</option>
                        <option value="America/New_York" {% if store.timezone == 'America/New_York' %}selected{% endif %}>Eastern Time</option>
                        <option value="America/Chicago" {% if store.timezone == 'America/Chicago' %}selected{% endif %}>Central Time</option>
                        <option value="America/Denver" {% if store.timezone == 'America/Denver' %}selected{% endif %}>Mountain Time</option>
                        <option value="America/Los_Angeles" {% if store.timezone == 'America/Los_Angeles' %}selected{% endif %}>Pacific Time</option>
                        <option value="Europe/London" {% if store.timezone == 'Europe/London' %}selected{% endif %}>London</option>
                        <option value="Asia/Kolkata" {% if store.timezone == 'Asia/Kolkata' %}selected{% endif %}>India Standard Time</option>
                    </select>
                </div>
                
                <div class="form-group">
                    <label for="language" class="form-label">Default Language</label>
                    <select id="language" name="language" class="form-select">
                        <option value="en" {% if store.language == 'en' %}selected{% endif %}>English</option>
                        <option value="es" {% if store.language == 'es' %}selected{% endif %}>Spanish</option>
                        <option value="fr" {% if store.language == 'fr' %}selected{% endif %}>French</option>
                        <option value="de" {% if store.language == 'de' %}selected{% endif %}>German</option>
                        <option value="hi" {% if store.language == 'hi' %}selected{% endif %}>Hindi</option>
                    </select>
                </div>
                
                <div class="form-group">
                    <label for="commission_rate" class="form-label">Commission Rate</label>
                    <input type="number" id="commission_rate" name="commission_rate" class="form-input" 
                           min="0" max="1" step="0.0001" value="{{ store.commission_rate|default('0.0000') }}">
                    <span class="form-hint">Decimal value between 0 and 1 (e.g., 0.05 for 5%)</span>
                </div>
            </div>
        </div>

        <!-- Branding -->
        <div class="settings-section">
            <h2 class="section-title">Branding</h2>
            <div class="form-grid">
                <div class="form-group">
                    <label for="store_logo" class="form-label">Store Logo</label>
                    <input type="file" id="store_logo" name="store_logo" class="form-file" accept="image/*">
                    <span class="form-hint">Recommended size: 200x200px, max 2MB</span>
                    {% if store.store_logo_url %}
                    <div class="current-image">
                        <img src="{{ create_url(store.store_logo_url) }}" alt="Current Logo" style="max-width: 100px; max-height: 100px; margin-top: 8px;">
                    </div>
                    {% endif %}
                </div>
                
                <div class="form-group">
                    <label for="store_banner" class="form-label">Store Banner</label>
                    <input type="file" id="store_banner" name="store_banner" class="form-file" accept="image/*">
                    <span class="form-hint">Recommended size: 1200x400px, max 5MB</span>
                    {% if store.store_banner_url %}
                    <div class="current-image">
                        <img src="{{ create_url(store.store_banner_url) }}" alt="Current Banner" style="max-width: 200px; max-height: 100px; margin-top: 8px;">
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>

        <!-- Social Links -->
        <div class="settings-section">
            <h2 class="section-title">Social Media Links</h2>
            <div class="form-grid">
                <div class="form-group">
                    <label for="social_facebook" class="form-label">Facebook</label>
                    <input type="url" id="social_facebook" name="social_facebook" class="form-input" 
                           placeholder="https://facebook.com/yourstore" value="{{ store.social_links.facebook|default('') }}">
                </div>
                
                <div class="form-group">
                    <label for="social_twitter" class="form-label">Twitter/X</label>
                    <input type="url" id="social_twitter" name="social_twitter" class="form-input" 
                           placeholder="https://twitter.com/yourstore" value="{{ store.social_links.twitter|default('') }}">
                </div>
                
                <div class="form-group">
                    <label for="social_instagram" class="form-label">Instagram</label>
                    <input type="url" id="social_instagram" name="social_instagram" class="form-input" 
                           placeholder="https://instagram.com/yourstore" value="{{ store.social_links.instagram|default('') }}">
                </div>
                
                <div class="form-group">
                    <label for="social_linkedin" class="form-label">LinkedIn</label>
                    <input type="url" id="social_linkedin" name="social_linkedin" class="form-input" 
                           placeholder="https://linkedin.com/company/yourstore" value="{{ store.social_links.linkedin|default('') }}">
                </div>
            </div>
        </div>

        <!-- Store Status -->
        <div class="settings-section">
            <h2 class="section-title">Store Status</h2>
            <div class="form-grid">
                <div class="form-group">
                    <label for="store_status" class="form-label">Store Status</label>
                    <select id="store_status" name="store_status" class="form-select">
                        <option value="active" {% if store.store_status == 'active' %}selected{% endif %}>Active</option>
                        <option value="inactive" {% if store.store_status == 'inactive' %}selected{% endif %}>Inactive</option>
                        <option value="pending_approval" {% if store.store_status == 'pending_approval' %}selected{% endif %}>Pending Approval</option>
                        <option value="closed" {% if store.store_status == 'closed' %}selected{% endif %}>Closed</option>
                    </select>
                </div>
                
                <div class="form-group">
                    <label class="checkbox-label">
                        <input type="checkbox" id="is_featured" name="is_featured" class="form-checkbox" {% if store.is_featured %}checked{% endif %}>
                        <span class="checkbox-text">Featured Store</span>
                    </label>
                </div>
            </div>
        </div>

        <!-- Form Actions -->
        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Save Settings</button>
            <button type="button" class="btn btn-secondary" onclick="window.location.reload()">Cancel</button>
            {% if store %}
            <button type="button" class="btn btn-danger" onclick="confirmDeleteStore({{ store.id }})">Delete Store</button>
            {% endif %}
        </div>
    </form>
</div>

<link rel="stylesheet" href="/modules/commerce_store/assets/css/store-settings.css">

<script>
// Form submission handling
document.getElementById('storeSettingsForm').addEventListener('submit', function(e) {
    e.preventDefault();
    
    const formData = new FormData(this);
    const submitBtn = this.querySelector('.btn-primary');
    
    // Show loading state
    submitBtn.classList.add('loading');
    submitBtn.disabled = true;
    
    fetch(window.location.href, {
        method: 'POST',
        body: formData,
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            // Show success message
            showNotification('success', data.success);
            // Reload page after a short delay to show updated data
            setTimeout(() => window.location.reload(), 1500);
        } else {
            showNotification('error', data.error || 'An error occurred');
        }
    })
    .catch(error => {
        showNotification('error', 'Network error occurred');
    })
    .finally(() => {
        submitBtn.classList.remove('loading');
        submitBtn.disabled = false;
    });
});

// Show notification
function showNotification(type, message) {
    const notification = document.createElement('div');
    notification.className = `notification ${type} show`;
    notification.textContent = message;
    
    document.querySelector('.store-settings').insertBefore(
        notification, 
        document.querySelector('.settings-form')
    );
    
    setTimeout(() => {
        notification.classList.remove('show');
        setTimeout(() => notification.remove(), 300);
    }, 5000);
}

// Confirm store deletion
function confirmDeleteStore(storeId) {
    if (confirm('Are you sure you want to delete this store? This action cannot be undone.')) {
        // Implement deletion logic
        fetch('/store/delete/' + storeId, {
            method: 'DELETE',
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                window.location.href = '/dashboard';
            } else {
                showNotification('error', data.error || 'Failed to delete store');
            }
        })
        .catch(error => {
            showNotification('error', 'Network error occurred');
        });
    }
}

// Auto-generate slug from store name
document.getElementById('store_name').addEventListener('input', function() {
    const slugField = document.getElementById('store_slug');
    if (!slugField.value || slugField.dataset.autoGenerated === 'true') {
        const slug = this.value.toLowerCase()
            .replace(/[^a-z0-9]+/g, '-')
            .replace(/-+/g, '-')
            .replace(/^-|-$/g, '');
        slugField.value = slug;
        slugField.dataset.autoGenerated = 'true';
    }
});

// Mark slug as manually edited
document.getElementById('store_slug').addEventListener('input', function() {
    this.dataset.autoGenerated = 'false';
});
</script>
{% endblock %}